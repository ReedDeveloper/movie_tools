TMDB_API_KEY=your_tmdb_api_key_here

# 飞书自定义机器人 Webhook（定时推荐推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here

# 飞书 App 凭证（可选，仅用于上传海报图片到飞书卡片）
# 未配置时飞书卡片不含图片，但仍会发送文字信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 其他推送通道（可选，不使用飞书时回退）
MOVIE_PUSH_WEBHOOK_URL=
SERVERCHAN_SENDKEY=
BARK_PUSH_URL=
